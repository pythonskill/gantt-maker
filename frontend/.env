# Environment variables for React development server
# Enable HTTPS for Codespaces (required for WSS WebSocket)
HTTPS=true
# Bind to all interfaces for Codespaces proxy
HOST=0.0.0.0

# WebSocket settings for webpack-dev-server (HMR)
WDS_SOCKET_PATH=/ws
WDS_SOCKET_HOST=0.0.0.0

# Disable source maps for faster builds
GENERATE_SOURCEMAP=false